#pragma once

// Copy this file to `secrets.h` and fill in the values.
// `secrets.h` is gitignored.

#define WIFI_SSID     "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// How to get the bot token:
//   1. Open Telegram, search for @BotFather
//   2. Send /newbot, follow the prompts to pick a name and username
//   3. BotFather replies with a token shaped like "123456789:AAH...xyz"
#define TELEGRAM_BOT_TOKEN "123456:ABC-DEF..."

// How to get your chat id:
//   1. In Telegram, search for @userinfobot and send it /start
//   2. It replies with your numeric user id — that's the chat id for DMs
//   3. To forward into a group instead, add the bot to the group, send any
//      message, then visit https://api.telegram.org/bot<TOKEN>/getUpdates
//      and read `result[].message.chat.id` (group chat ids are negative)
//
// Single-user form (keep for backward compatibility):
#define TELEGRAM_CHAT_ID   "0000000000"
//
// Multi-user form: comment out TELEGRAM_CHAT_ID above and uncomment the
// line below instead. Comma-separated list of Telegram user IDs. Maximum
// 10 entries. The first entry is the admin — SMS forwards go to that chat.
// All listed users may send replies and use /status / /debug.
// Example: "111111111,222222222,333333333"
// #define TELEGRAM_CHAT_IDS "0000000000"

// Cellular APN for GPRS/LTE data fallback (RFC-0004).
//
// When WiFi is unavailable the bridge tries to reach Telegram via the SIM's
// data bearer. Define CELLULAR_APN to the APN string for your SIM operator.
// Common examples:
//   "internet"      — generic; works for many SIMs
//   "CHN-CT"        — China Telecom
//   "cmnet"         — China Mobile
//   ""              — empty string; many SIMs auto-negotiate an APN
//
// If CELLULAR_APN is NOT defined here, cellular fallback is compiled out
// and the bridge will log "Cellular fallback not available" if WiFi fails.
//
// NOTE: The cellular TLS path uses authmode=0 (no server certificate
// verification). A [CELLULAR TLS] warning is printed at boot whenever
// the modem transport is active. See rfc/0004-cellular-fallback.md.
#define CELLULAR_APN  ""

// Optional: heartbeat interval in seconds (0 = disabled, default = 21600 = 6h, min 300 = 5m)
// #define HEARTBEAT_INTERVAL_SEC 21600

// Optional: comma-separated phone numbers to block (silently delete without forwarding).
// Both national and E.164 formats may need to be listed separately.
// Example: #define SMS_BLOCK_LIST "10086,+8610086,10010"
// #define SMS_BLOCK_LIST ""
