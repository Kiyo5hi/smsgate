#pragma once

// Copy this file to `secrets.h` and fill in the values.
// `secrets.h` is gitignored.

#define WIFI_SSID     "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// How to get the bot token:
//   1. Open Telegram, search for @BotFather
//   2. Send /newbot, follow the prompts to pick a name and username
//   3. BotFather replies with a token shaped like "123456789:AAH...xyz"
#define TELEGRAM_BOT_TOKEN "123456:ABC-DEF..."

// How to get your chat id:
//   1. In Telegram, search for @userinfobot and send it /start
//   2. It replies with your numeric user id — that's the chat id for DMs
//   3. To forward into a group instead, add the bot to the group, send any
//      message, then visit https://api.telegram.org/bot<TOKEN>/getUpdates
//      and read `result[].message.chat.id` (group chat ids are negative)
#define TELEGRAM_CHAT_ID   "0000000000"
